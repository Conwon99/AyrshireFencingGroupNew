---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { GalleryPage } from "@/pages/gallery/_GalleryPage";
import { CTASection } from "@/sections/Footer/components/CTASection";
import { Footer } from "@/sections/Footer";
---

<BaseLayout
  title="Gallery | Fencing & Decking Projects Ayrshire | Ayrshire Fencing Group"
  description="Browse our gallery of completed fencing and decking projects across Ayrshire. See the quality of our craftsmanship and get inspired for your own project."
  canonical="https://www.ayrshirefencinggroup.com/gallery"
>
  <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
    <Header client:load />
    <GalleryPage client:load />
    <CTASection client:load />
    <Footer client:load />
  </div>
</BaseLayout>
